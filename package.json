{
  "name": "design-research-mcp",
  "version": "0.1.0",
  "description": "MCP server that decomposes websites into a searchable library of reusable design components",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "design-research-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "css-tree": "^3.2.1",
    "playwright": "^1.61.1",
    "sqlite-vec": "^0.1.9",
    "voyageai": "^0.4.0",
    "zod": "^4.4.3"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
